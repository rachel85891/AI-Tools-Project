{
  "version": "3.8",
  "services": {
    "webapishop": {
      "build": {
        "context": ".",
        "dockerfile": "./WebApiShop/Dockerfile"
      },
      "ports": [
        "8080:80"
      ],
      "environment": [
        "ASPNETCORE_ENVIRONMENT=Development",
        "REDIS__HOST=redis",
        "REDIS__PORT=6379",
        "REDIS__PASSWORD=YOUR_SECRET_PASSWORD"
      ],
      "depends_on": [
        "redis"
      ],
      "restart": "unless-stopped"
    },
    "redis": {
      "image": "redis:alpine",
      "command": [
        "redis-server",
        "--requirepass",
        "YOUR_SECRET_PASSWORD"
      ],
      "ports": [
        "6379:6379"
      ],
      "restart": "unless-stopped",
      "healthcheck": {
        "test": [
          "CMD",
          "redis-cli",
          "-a",
          "YOUR_SECRET_PASSWORD",
          "ping"
        ],
        "interval": "10s",
        "timeout": "5s",
        "retries": 5,
        "start_period": "5s"
      }
    }
  }
}