using System.Net.Http.Json;
using Microsoft.AspNetCore.Mvc.Testing;
using Xunit;
using DTOs;
using Microsoft.Extensions.DependencyInjection;
using Microsoft.EntityFrameworkCore;
using Entities;
using Repositories;
using System.Threading.Tasks;
using System.Net;

namespace Tests
{
    public class UserAuthenticationTests : IClassFixture<WebApplicationFactory<WebApiShop.Startup>>
    {
        private readonly WebApplicationFactory<WebApiShop.Startup> _factory;

        public UserAuthenticationTests(WebApplicationFactory<WebApiShop.Startup> factory)
        {
            _factory = factory;
        }

        [Fact]
        public async Task Register_SavesHashedPassword_AndLoginSucceeds()
        {
            // create per-test in-memory sqlite connection
            using var connection = new Microsoft.Data.Sqlite.SqliteConnection("DataSource=:memory:");
            connection.Open();

            var factory = _factory.WithWebHostBuilder(builder =>
            {
                builder.UseSetting("environment", "Testing");
                builder.ConfigureServices(services =>
                {
                    // remove existing db registrations
                    var descriptors = services.Where(d => d.ServiceType == typeof(DbContextOptions<ShowsCenterContext>) || d.ServiceType == typeof(ShowsCenterContext)).ToList();
                    foreach (var d in descriptors) services.Remove(d);

                    services.AddDbContext<ShowsCenterContext>(options => options.UseSqlite(connection));
                });
            });

            var client = factory.CreateClient();

            var register = new UserCreateDTO("T", "U", "int_test@example.com", "000000000", "my-secret-123");
            var resp = await client.PostAsJsonAsync("/api/Users/user", register);
            Assert.Equal(HttpStatusCode.Created, resp.StatusCode);

            // Check database to ensure stored password is not plain
            using var scope = factory.Services.CreateScope();
            var repo = scope.ServiceProvider.GetRequiredService<IUserRepository>();
            var user = await repo.getUserByEmail(register.EmailAddress);
            Assert.NotNull(user);
            Assert.NotEqual(register.Password, user.Password);
            // Basic sanity: stored password should look like a bcrypt hash (starts with $2)
            Assert.StartsWith("$2", user.Password);

            // Now login
            var login = new UserLoginDTO(register.EmailAddress, register.Password);
            var loginResp = await client.PostAsJsonAsync("/api/Users/loginUser", login);
            Assert.Equal(HttpStatusCode.OK, loginResp.StatusCode);
        }
    }
}
