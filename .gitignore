# ==============================================================================
# Monorepo .gitignore (Client & Server)
# ==============================================================================

# --- 1. Client (Angular/Node.js) ---
/client/dist
/client/tmp
/client/out-tsc
/client/node_modules
/client/.angular/cache
/client/.sass-cache
/client/coverage
npm-debug.log
yarn-error.log

# --- 2. Server (Visual Studio/C#/.NET) ---
# Build Results
[Dd]ebug/
[Rr]elease/
[Bb]in/
[Oo]bj/
[Oo]ut/

# Visual Studio Cache & User files
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.pdb
*.binlog

# NuGet
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nupkg

# --- 3. General System & IDE Files ---
# System
.DS_Store
Thumbs.db
docker-compose.yml

# IDEs
.vscode/
.history/
.idea/
.project
.classpath
.settings/

# --- 4. Environment & Sensitive Data ---
# It is critical to ignore environment variables and local database config
.env
appsettings.Development.json

# --- 5. Miscellaneous ---
*.tmp
*.log
*.bak